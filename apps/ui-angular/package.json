{
  "name": "@veriframe/ui-angular",
  "version": "0.1.0",
  "private": true,
  "description": "Angular frontend for VeriFrame.",
  "type": "module",
  "scripts": {
    "dev": "ng serve --host 127.0.0.1 --port 4200",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "test": "node ../../tools/dev/run-ui-vitest.mjs run --config vitest.config.ts",
    "test:watch": "node ../../tools/dev/run-ui-vitest.mjs --config vitest.config.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "ng build --configuration development"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@tauri-apps/api": "^2.6.0",
    "@veriframe/contracts": "workspace:*",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}

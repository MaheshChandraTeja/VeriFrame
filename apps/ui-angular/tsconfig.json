{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc/ui-angular",
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@veriframe/contracts": ["../../packages/contracts/src/index.ts"],
      "@app/*": ["src/app/*"]
    }
  },
  "angularCompilerOptions": {
    "strictTemplates": true,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true
  },
  "files": [
    "src/main.ts"
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/test-setup.ts"
  ]
}

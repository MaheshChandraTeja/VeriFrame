{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VeriFrame",
  "version": "0.1.0",
  "identifier": "com.kairais.veriframe",
  "build": {
    "beforeDevCommand": "pnpm --dir ../.. --filter @veriframe/ui-angular dev",
    "devUrl": "http://127.0.0.1:4200",
    "beforeBuildCommand": "pnpm --dir ../.. --filter @veriframe/ui-angular build",
    "frontendDist": "../../../dist/ui-angular/browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VeriFrame",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "Copyright © Kairais Tech",
    "shortDescription": "Local-first visual audit engine",
    "longDescription": "VeriFrame is a local-first visual audit engine powered by TorchVision.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}

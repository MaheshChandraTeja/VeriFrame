{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veriframe.local/schemas/audit-receipt.schema.json",
  "title": "AuditReceipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "receiptId",
    "runId",
    "generatedAt",
    "inputHash",
    "resultHash",
    "configHash",
    "modelRefs",
    "artifactHashes",
    "signature"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "receiptId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "inputHash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "resultHash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "configHash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "modelRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "modelId",
          "version",
          "configHash"
        ],
        "properties": {
          "modelId": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "configHash": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "checkpointHash": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          }
        }
      }
    },
    "artifactHashes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifactId",
          "path",
          "sha256"
        ],
        "properties": {
          "artifactId": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256-local-integrity"
        },
        "value": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veriframe.local/schemas/analysis-result.schema.json",
  "title": "AnalysisResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "requestId",
    "status",
    "createdAt",
    "image",
    "modelInfo",
    "qualityReport",
    "regions",
    "findings",
    "auditReceipt",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "imageId",
        "fileName",
        "sha256",
        "mimeType",
        "width",
        "height",
        "sizeBytes",
        "exifPresent"
      ],
      "properties": {
        "imageId": {
          "type": "string",
          "minLength": 1
        },
        "fileName": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "mimeType": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "exifPresent": {
          "type": "boolean"
        }
      }
    },
    "modelInfo": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "modelId",
          "name",
          "version",
          "task",
          "framework",
          "device",
          "labels",
          "configHash"
        ],
        "properties": {
          "modelId": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "task": {
            "type": "string",
            "enum": [
              "classification",
              "detection",
              "segmentation"
            ]
          },
          "framework": {
            "const": "torchvision"
          },
          "device": {
            "type": "string",
            "enum": [
              "cpu",
              "cuda",
              "mps"
            ]
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "configHash": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "checkpointHash": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          }
        }
      }
    },
    "qualityReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blurScore",
        "brightness",
        "contrast",
        "glareRisk",
        "resolutionAdequate",
        "warnings"
      ],
      "properties": {
        "blurScore": {
          "type": "number",
          "minimum": 0
        },
        "brightness": {
          "type": "number",
          "minimum": 0
        },
        "contrast": {
          "type": "number",
          "minimum": 0
        },
        "glareRisk": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high"
          ]
        },
        "resolutionAdequate": {
          "type": "boolean"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "regionId",
          "label",
          "category",
          "confidence",
          "bbox",
          "sourceModelId",
          "rationale",
          "reviewStatus"
        ],
        "properties": {
          "regionId": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "receipt_header",
              "line_item_block",
              "price_label",
              "product_package",
              "damage_zone",
              "display_panel",
              "sensitive_region",
              "unknown"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "bbox": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "x",
              "y",
              "width",
              "height"
            ],
            "properties": {
              "x": {
                "type": "number",
                "minimum": 0
              },
              "y": {
                "type": "number",
                "minimum": 0
              },
              "width": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "height": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            }
          },
          "mask": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "format"
            ],
            "properties": {
              "format": {
                "type": "string",
                "enum": [
                  "polygon",
                  "rle"
                ]
              },
              "points": {
                "type": "array",
                "items": {
                  "type": "array",
                  "prefixItems": [
                    {
                      "type": "number"
                    },
                    {
                      "type": "number"
                    }
                  ],
                  "items": false,
                  "minItems": 2,
                  "maxItems": 2
                }
              },
              "rle": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "counts",
                  "size"
                ],
                "properties": {
                  "counts": {
                    "type": "array",
                    "items": {
                      "type": "integer",
                      "minimum": 0
                    }
                  },
                  "size": {
                    "type": "array",
                    "prefixItems": [
                      {
                        "type": "integer",
                        "minimum": 1
                      },
                      {
                        "type": "integer",
                        "minimum": 1
                      }
                    ],
                    "items": false,
                    "minItems": 2,
                    "maxItems": 2
                  }
                }
              }
            }
          },
          "sourceModelId": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "reviewStatus": {
            "type": "string",
            "enum": [
              "unreviewed",
              "accepted",
              "corrected",
              "rejected"
            ]
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "findingId",
          "title",
          "description",
          "severity",
          "confidence",
          "regionIds",
          "evidenceRefs",
          "recommendation"
        ],
        "properties": {
          "findingId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "regionIds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "auditReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "receiptId",
        "runId",
        "generatedAt",
        "inputHash",
        "resultHash",
        "configHash",
        "modelRefs",
        "artifactHashes",
        "signature"
      ],
      "properties": {
        "schemaVersion": {
          "const": "1.0.0"
        },
        "receiptId": {
          "type": "string",
          "minLength": 1
        },
        "runId": {
          "type": "string",
          "minLength": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "inputHash": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "resultHash": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "configHash": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "modelRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "modelId",
              "version",
              "configHash"
            ],
            "properties": {
              "modelId": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "configHash": {
                "type": "string",
                "pattern": "^[a-fA-F0-9]{64}$"
              },
              "checkpointHash": {
                "type": "string",
                "pattern": "^[a-fA-F0-9]{64}$"
              }
            }
          }
        },
        "artifactHashes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifactId",
              "path",
              "sha256"
            ],
            "properties": {
              "artifactId": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-fA-F0-9]{64}$"
              }
            }
          }
        },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "algorithm",
            "value"
          ],
          "properties": {
            "algorithm": {
              "const": "sha256-local-integrity"
            },
            "value": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{64}$"
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}